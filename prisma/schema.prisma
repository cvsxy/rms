generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTHENTICATION & USERS ────────────────────────────────────

enum UserRole {
  SERVER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  pin       String?
  email     String?  @unique
  password  String?
  role      UserRole @default(SERVER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders            Order[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]
  appliedDiscounts  OrderDiscount[]
  dailyCloses       DailyClose[]

  @@index([pin])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─── MENU ───────────────────────────────────────────────────────

model MenuCategory {
  id        String   @id @default(cuid())
  name      String
  nameEs    String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MenuItem[]

  @@index([sortOrder])
}

enum ItemDestination {
  KITCHEN
  BAR
}

model MenuItem {
  id            String          @id @default(cuid())
  name          String
  nameEs        String
  description   String?
  descriptionEs String?
  price         Decimal         @db.Decimal(10, 2)
  destination   ItemDestination
  categoryId    String
  active        Boolean         @default(true)
  available     Boolean         @default(true)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  category    MenuCategory         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  modifiers   Modifier[]
  orderItems  OrderItem[]
  ingredients MenuItemIngredient[]

  @@index([categoryId])
  @@index([destination])
  @@index([active])
}

model Modifier {
  id         String   @id @default(cuid())
  name       String
  nameEs     String
  priceAdj   Decimal  @default(0) @db.Decimal(10, 2)
  menuItemId String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  menuItem      MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItemMods OrderItemModifier[]

  @@index([menuItemId])
}

// ─── CUSTOMERS & CRM ──────────────────────────────────────────

model Customer {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  email        String?
  notes        String?
  dietaryNotes String?
  tags         String[]  @default([])
  totalVisits  Int       @default(0)
  totalSpent   Decimal   @default(0) @db.Decimal(10, 2)
  lastVisit    DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders        Order[]
  reservations  Reservation[]
  loyaltyMember LoyaltyMember?

  @@index([phone])
  @@index([name])
}

// ─── RESERVATIONS ──────────────────────────────────────────────

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  PHONE
  WALKIN
  WHATSAPP
  WEBSITE
  MANUAL
}

model Reservation {
  id           String            @id @default(cuid())
  customerId   String?
  guestName    String
  guestPhone   String
  guestEmail   String?
  date         DateTime          @db.Date
  time         String
  partySize    Int
  tableId      String?
  status       ReservationStatus @default(PENDING)
  source       ReservationSource @default(MANUAL)
  notes        String?
  confirmedAt  DateTime?
  seatedAt     DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  reminderSent Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  customer Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  table    RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([status])
  @@index([customerId])
  @@index([guestPhone])
}

// ─── WAITLIST ──────────────────────────────────────────────────

model WaitlistEntry {
  id            String    @id @default(cuid())
  guestName     String
  guestPhone    String
  partySize     Int
  estimatedWait Int?
  notes         String?
  notifiedAt    DateTime?
  seatedAt      DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([createdAt])
}

// ─── TABLES ─────────────────────────────────────────────────────

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

model RestaurantTable {
  id        String      @id @default(cuid())
  number    Int         @unique
  name      String?
  seats     Int         @default(4)
  status    TableStatus @default(AVAILABLE)
  active    Boolean     @default(true)
  posX      Float?
  posY      Float?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders       Order[]
  reservations Reservation[]

  @@index([status])
  @@index([number])
}

// ─── ORDERS ─────────────────────────────────────────────────────

enum OrderStatus {
  OPEN
  SUBMITTED
  COMPLETED
  CLOSED
  CANCELLED
}

model Order {
  id         String      @id @default(cuid())
  tableId    String
  serverId   String
  customerId String?
  status     OrderStatus @default(OPEN)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  table     RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Restrict)
  server    User            @relation(fields: [serverId], references: [id], onDelete: Restrict)
  customer  Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items     OrderItem[]
  payment   Payment?
  discounts OrderDiscount[]
  courses   OrderCourse[]

  @@index([tableId])
  @@index([serverId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

// ─── COURSE FIRING ─────────────────────────────────────────────

model OrderCourse {
  id           String    @id @default(cuid())
  orderId      String
  courseNumber  Int
  label        String?
  firedAt      DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, courseNumber])
  @@index([orderId])
}

enum OrderItemStatus {
  PENDING
  SENT
  PREPARING
  READY
  SERVED
  CANCELLED
}

model OrderItem {
  id           String          @id @default(cuid())
  orderId      String
  menuItemId   String
  quantity     Int             @default(1)
  unitPrice    Decimal         @db.Decimal(10, 2)
  notes        String?
  seatNumber   Int?
  courseNumber  Int?
  status       OrderItemStatus @default(PENDING)
  sentAt     DateTime?
  readyAt    DateTime?
  servedAt   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  order      Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  modifiers  OrderItemModifier[]
  voidReason String?
  voidNote   String?

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
}

model OrderItemModifier {
  id          String  @id @default(cuid())
  orderItemId String
  modifierId  String
  priceAdj    Decimal @default(0) @db.Decimal(10, 2)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier  Modifier  @relation(fields: [modifierId], references: [id], onDelete: Restrict)

  @@unique([orderItemId, modifierId])
  @@index([orderItemId])
}

// ─── PUSH SUBSCRIPTIONS ─────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  auth      String
  p256dh    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

// ─── INVENTORY ──────────────────────────────────────────────────

model Ingredient {
  id                String   @id @default(cuid())
  name              String
  nameEs            String
  unit              String   // "kg", "L", "units", "g", "ml", "oz"
  currentStock      Decimal  @default(0) @db.Decimal(10, 3)
  lowStockThreshold Decimal  @default(0) @db.Decimal(10, 3)
  costPerUnit       Decimal  @default(0) @db.Decimal(10, 2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  menuItems MenuItemIngredient[]

  @@index([active])
}

model MenuItemIngredient {
  id           String  @id @default(cuid())
  menuItemId   String
  ingredientId String
  quantity     Decimal @db.Decimal(10, 3)

  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
}

// ─── SETTINGS ───────────────────────────────────────────────────

model RestaurantSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@index([key])
}

// ─── PAYMENTS ───────────────────────────────────────────────────

enum PaymentMethod {
  CASH
  CARD
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  method    PaymentMethod
  subtotal  Decimal       @db.Decimal(10, 2)
  tax       Decimal       @db.Decimal(10, 2)
  total     Decimal       @db.Decimal(10, 2)
  tip       Decimal       @default(0) @db.Decimal(10, 2)
  discount  Decimal       @default(0) @db.Decimal(10, 2)
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// ─── DISCOUNTS ──────────────────────────────────────────────────

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Discount {
  id        String       @id @default(cuid())
  name      String
  nameEs    String
  type      DiscountType
  value     Decimal      @db.Decimal(10, 2)
  code      String?      @unique
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  orderDiscounts OrderDiscount[]

  @@index([active])
}

model OrderDiscount {
  id          String       @id @default(cuid())
  orderId     String
  discountId  String?
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)
  appliedById String
  note        String?
  createdAt   DateTime     @default(now())

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discount  Discount? @relation(fields: [discountId], references: [id], onDelete: SetNull)
  appliedBy User      @relation(fields: [appliedById], references: [id], onDelete: Restrict)

  @@index([orderId])
}

// ─── LOYALTY PROGRAM ───────────────────────────────────────────

model LoyaltyProgram {
  id            String   @id @default(cuid())
  name          String
  nameEs        String
  pointsPerPeso Decimal  @default(1) @db.Decimal(5, 2)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rewards LoyaltyReward[]
  members LoyaltyMember[]
}

model LoyaltyMember {
  id            String   @id @default(cuid())
  customerId    String   @unique
  programId     String
  pointsBalance Int      @default(0)
  totalEarned   Int      @default(0)
  totalRedeemed Int      @default(0)
  tier          String   @default("BRONZE")
  joinedAt      DateTime @default(now())

  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  program      LoyaltyProgram       @relation(fields: [programId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([programId])
  @@index([customerId])
}

enum LoyaltyTxType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
}

model LoyaltyTransaction {
  id          String        @id @default(cuid())
  memberId    String
  type        LoyaltyTxType
  points      Int
  orderId     String?
  rewardId    String?
  description String?
  createdAt   DateTime      @default(now())

  member LoyaltyMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  reward LoyaltyReward? @relation(fields: [rewardId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([createdAt])
}

model LoyaltyReward {
  id         String       @id @default(cuid())
  programId  String
  name       String
  nameEs     String
  pointsCost Int
  type       DiscountType
  value      Decimal      @db.Decimal(10, 2)
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())

  program      LoyaltyProgram       @relation(fields: [programId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([programId])
}

// ─── GIFT CARDS ────────────────────────────────────────────────

model GiftCard {
  id             String    @id @default(cuid())
  code           String    @unique
  originalAmount Decimal   @db.Decimal(10, 2)
  balance        Decimal   @db.Decimal(10, 2)
  purchaserName  String?
  recipientName  String?
  recipientPhone String?
  expiresAt      DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  usages GiftCardUsage[]

  @@index([code])
  @@index([active])
}

model GiftCardUsage {
  id         String   @id @default(cuid())
  giftCardId String
  orderId    String?
  amount     Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
}

// ─── AUDIT LOG ──────────────────────────────────────────────────

enum AuditAction {
  ITEM_VOIDED
  ORDER_CANCELLED
  PAYMENT_PROCESSED
  DISCOUNT_APPLIED
  ITEM_86D
  STOCK_ADJUSTED
  DAILY_CLOSED
  RESERVATION_CREATED
  RESERVATION_CANCELLED
  RESERVATION_NO_SHOW
  LOYALTY_REDEEMED
  GIFT_CARD_REDEEMED
  COURSE_FIRED
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  userId      String
  orderId     String?
  orderItemId String?
  details     Json?
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@index([orderId])
}

// ─── DAILY CLOSE ───────────────────────────────────────────────

model DailyClose {
  id            String   @id @default(cuid())
  date          DateTime @unique @db.Date
  expectedCash  Decimal  @db.Decimal(10, 2)
  actualCash    Decimal  @db.Decimal(10, 2)
  variance      Decimal  @db.Decimal(10, 2)
  cardTotal     Decimal  @db.Decimal(10, 2)
  totalRevenue  Decimal  @db.Decimal(10, 2)
  totalTax      Decimal  @db.Decimal(10, 2)
  totalTips     Decimal  @db.Decimal(10, 2)
  totalDiscount Decimal  @db.Decimal(10, 2)
  subtotal      Decimal  @db.Decimal(10, 2)
  orderCount    Int
  closedById    String
  notes         String?
  createdAt     DateTime @default(now())

  closedBy User @relation(fields: [closedById], references: [id], onDelete: Restrict)

  @@index([date])
}
